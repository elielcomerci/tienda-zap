# Variables de entorno — ZAP Tienda
# Copiar a .env.local y completar los valores

# Base de datos PostgreSQL (Neon)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# En producción: NEXTAUTH_URL="https://tienda.zap.com.ar"

# Vercel Blob (se genera automáticamente al vincular el Blob store)
BLOB_READ_WRITE_TOKEN=""

# MercadoPago
MP_ACCESS_TOKEN="APP_USR-..."
MP_WEBHOOK_SECRET=""
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-..."

# Admin inicial
ADMIN_EMAIL="admin@zap.com.ar"
ADMIN_PASSWORD="cambiar_esta_clave"

# Cloudflare R2 (media.zap.com.ar)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Integración con kiosco24 (Impresión Premium / Crédito Partner)
KIOSCO24_BASE_URL="http://localhost:3001"
# Secret compartido con kiosco24 — debe coincidir con PARTNER_INTERNAL_SECRET allá
PARTNER_INTERNAL_SECRET="cambiar_esta_clave_compartida"
