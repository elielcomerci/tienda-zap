generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  password           String
  role               Role           @default(CUSTOMER)
  name               String?
  phone              String?
  isBanned           Boolean        @default(false)
  sellerId           String?
  createdAt          DateTime       @default(now())
  billingAddress     String?
  billingCity        String?
  billingProvince    String?
  documentId         String?
  shippingAddress    String?
  shippingCity       String?
  shippingPostalCode String?
  shippingProvince   String?
  businessTypeId     String?
  businessType       BusinessType?  @relation(fields: [businessTypeId], references: [id])
  accounts           Account[]
  orders             Order[]        @relation("CustomerOrders")
  sellerOrders       Order[]        @relation("OrderSeller")
  sessions           Session[]
  seller             User?          @relation("SellerClients", fields: [sellerId], references: [id])
  clients            User[]         @relation("SellerClients")
  sellerProfile      SellerProfile?
}

model SellerProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  defaultCommissionRate Float    @default(20.0)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessType {
  id         String     @id @default(cuid())
  name       String
  slug       String     @unique
  categories Category[]
  users      User[]
}

model Category {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  isService     Boolean        @default(false)
  products      Product[]
  businessTypes BusinessType[]
}

model Intention {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  icon        String?
  description String?
  mediaType   String?  @default("NONE") // "YOUTUBE", "AUDIO", "NONE"
  mediaUrl    String?
  mediaTitle  String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[] @relation("ProductIntentions")
}

model Product {
  id                       String            @id @default(cuid())
  name                     String
  slug                     String            @unique
  description              String?
  price                    Float
  images                   String[]
  categoryId               String
  active                   Boolean           @default(true)
  stock                    Int               @default(0)
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  creditDownPaymentPercent Int               @default(30)
  orderItems               OrderItem[]
  category                 Category          @relation(fields: [categoryId], references: [id])
  options                  ProductOption[]
  outgoingRelations        ProductRelation[] @relation("ProductOutgoingRelations")
  incomingRelations        ProductRelation[] @relation("ProductIncomingRelations")
  variants                 ProductVariant[]
  intentions               Intention[]       @relation("ProductIntentions")
}

model Order {
  id                    String            @id @default(cuid())
  userId                String?
  sellerId              String?
  guestEmail            String?
  guestName             String?
  guestPhone            String?
  subtotal              Float?
  discountTotal         Float             @default(0)
  total                 Float
  couponCode            String?
  pricingSnapshot       Json?
  status                OrderStatus       @default(PENDING)
  paymentType           PaymentType
  paymentId             String?
  commissionAmount      Float?
  receiptUrl            String?
  invoiceUrl            String?
  invoiceFileName       String?
  invoiceUploadedAt     DateTime?
  notes                 String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  publicAccessTokenHash String?
  mpPreferenceId        String?
  partnerAccountId      String?
  billingAddress        String?
  billingCity           String?
  billingProvince       String?
  documentId            String?
  shippingAddress       String?
  shippingCity          String?
  shippingPostalCode    String?
  shippingProvince      String?
  partnerAccount        PartnerAccount?   @relation(fields: [partnerAccountId], references: [id])
  user                  User?             @relation("CustomerOrders", fields: [userId], references: [id])
  seller                User?             @relation("OrderSeller", fields: [sellerId], references: [id])
  items                 OrderItem[]
  couponRedemption      CouponRedemption?
  zapCreditPlan         ZapCreditPlan?
  receipts              Receipt[]
  events                OrderEvent[]
  proofs                ProofFile[]
}

model OrderItem {
  id                       String                   @id @default(cuid())
  orderId                  String
  productId                String
  quantity                 Int
  unitPrice                Float
  notes                    String?
  designRequested          Boolean                  @default(false)
  fileUrl                  String?
  artworkSubmissionChannel ArtworkSubmissionChannel @default(PENDING)
  fileContentType          String?
  fileObjectKey            String?
  fileOriginalName         String?
  fileSizeBytes            Int?
  fileUploadedAt           DateTime?
  isService                Boolean                  @default(false)
  creditDownPaymentPercent Int                      @default(30)
  order                    Order                    @relation(fields: [orderId], references: [id])
  product                  Product                  @relation(fields: [productId], references: [id])
  selectedOptions          OrderItemOption[]
}

model FinancingSettings {
  id                                  String           @id @default("default")
  indecSeriesId                       String           @default("101.1_I2NG_2016_M_22")
  manualRatePercent                   Float?
  defaultInstallments                 Int              @default(6)
  defaultPaymentFrequency             PaymentFrequency @default(MONTHLY)
  cardInstallments                    Int              @default(6)
  createdAt                           DateTime         @default(now())
  updatedAt                           DateTime         @updatedAt
  delinquentDownPaymentPenaltyPercent Int              @default(10)
  delinquentRatePenaltyPercent        Float            @default(8)
}

model ZapCreditPlan {
  id                  String                       @id @default(cuid())
  orderId             String                       @unique
  status              ZapCreditStatus              @default(REQUESTED)
  rateSource          FinancingRateSource          @default(INDEC_AVERAGE)
  indecAveragePercent Float?
  ratePercent         Float
  installments        Int
  paymentFrequency    PaymentFrequency             @default(MONTHLY)
  firstDueDate        DateTime?
  baseAmount          Float
  downPaymentPercent  Float
  downPaymentAmount   Float
  financedAmount      Float
  installmentAmount   Float
  totalRepayable      Float
  totalInterest       Float
  notes               String?
  quotedAt            DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  scheduleItems       ZapCreditInstallment[]
  paymentSubmissions  ZapCreditPaymentSubmission[]
  order               Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ZapCreditInstallment {
  id                   String                       @id @default(cuid())
  planId               String
  sequence             Int
  dueDate              DateTime
  amount               Float
  principalAmount      Float
  interestAmount       Float
  balanceAfter         Float
  status               ZapCreditInstallmentStatus   @default(PENDING)
  approvedSubmissionId String?
  submittedAt          DateTime?
  approvedAt           DateTime?
  reviewNotes          String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  mpPreferenceId       String?
  plan                 ZapCreditPlan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  submissions          ZapCreditPaymentSubmission[]
  receipts             Receipt[]

  @@unique([planId, sequence])
}

model ZapCreditPaymentSubmission {
  id                      String                           @id @default(cuid())
  installmentId           String
  planId                  String
  submittedByUserId       String?
  reviewedByUserId        String?
  paymentMethod           ZapCreditPaymentMethod           @default(TRANSFER)
  amount                  Float
  proofUrl                String
  proofFileName           String
  proofContentType        String?
  proofSizeBytes          Int?
  proofHash               String
  duplicateOfSubmissionId String?
  notes                   String?
  reviewNotes             String?
  status                  ZapCreditPaymentSubmissionStatus @default(SUBMITTED)
  reviewedAt              DateTime?
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  duplicateOfSubmission   ZapCreditPaymentSubmission?      @relation("CreditSubmissionDuplicates", fields: [duplicateOfSubmissionId], references: [id])
  duplicateSubmissions    ZapCreditPaymentSubmission[]     @relation("CreditSubmissionDuplicates")
  installment             ZapCreditInstallment             @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  plan                    ZapCreditPlan                    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, status])
  @@index([proofHash])
}

model OrderItemOption {
  id          String    @id @default(cuid())
  orderItemId String
  optionName  String
  valueName   String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model ProductOption {
  id         String               @id @default(cuid())
  productId  String
  name       String
  isRequired Boolean              @default(true)
  product    Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values     ProductOptionValue[]
}

model ProductOptionValue {
  id       String          @id @default(cuid())
  optionId String
  value    String
  option   ProductOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants VariantOption[]
}

model ProductVariant {
  id        String          @id @default(cuid())
  productId String
  price     Float
  sku       String?
  stock     Int?
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  options   VariantOption[]
}

model ProductRelation {
  id               String   @id @default(cuid())
  productId        String
  relatedProductId String
  createdAt        DateTime @default(now())
  product          Product  @relation("ProductOutgoingRelations", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct   Product  @relation("ProductIncomingRelations", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
}

model VariantOption {
  id            String             @id @default(cuid())
  variantId     String
  optionValueId String
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PartnerAccount {
  id                 String   @id @default(cuid())
  kiosco24BranchId   String   @unique
  kiosco24BranchName String
  kiosco24AccessKey  String   @unique
  kiosco24OwnerEmail String?
  logoUrl            String?
  primaryColor       String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  orders             Order[]

  @@index([kiosco24AccessKey])
}

model PartnerCampaign {
  id              String   @id @default(cuid())
  zone            String
  format          String
  title           String
  description     String?
  ctaText         String?
  imageUrl        String?
  backgroundColor String?
  textColor       String?
  actionType      String
  actionUrl       String?
  productId       String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  discountKind    String?
  discountValue   Float?
  promoType       String?

  @@index([zone, active])
}

model Promotion {
  id            String             @id @default(cuid())
  name          String
  type          PromotionType      @default(COUPON)
  status        PromotionStatus    @default(DRAFT)
  campaignKind  String?
  audienceLabel String?
  qrBaseUrl     String?
  priority      Int                @default(0)
  stackable     Boolean            @default(false)
  activeFrom    DateTime?
  activeTo      DateTime?
  discountKind  DiscountKind
  discountValue Float
  maxUses       Int?
  perUserLimit  Int?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  coupons       PromotionCoupon[]
  redemptions   CouponRedemption[]
}

model PromotionCoupon {
  code              String             @id
  promotionId       String
  status            CouponStatus       @default(AVAILABLE)
  usesLeft          Int                @default(1)
  recipientName     String?
  recipientBusiness String?
  recipientEmail    String?
  recipientPhone    String?
  batchName         String?
  qrPayload         String?
  scanCount         Int                @default(0)
  lastScannedAt     DateTime?
  metadata          Json?
  expiresAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  promotion         Promotion          @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  redemptions       CouponRedemption[]
  scans             CouponScan[]

  @@index([promotionId, status])
  @@index([batchName])
}

model CouponScan {
  id         String          @id @default(cuid())
  couponCode String
  scannedAt  DateTime        @default(now())
  userAgent  String?
  referrer   String?
  coupon     PromotionCoupon @relation(fields: [couponCode], references: [code], onDelete: Cascade)

  @@index([couponCode, scannedAt])
}

model CouponRedemption {
  id             String                 @id @default(cuid())
  orderId        String                 @unique
  promotionId    String
  couponCode     String
  status         CouponRedemptionStatus @default(RESERVED)
  discountAmount Float
  createdAt      DateTime               @default(now())
  confirmedAt    DateTime?
  releasedAt     DateTime?
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotion      Promotion              @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  coupon         PromotionCoupon        @relation(fields: [couponCode], references: [code], onDelete: Cascade)

  @@index([promotionId, status])
  @@index([couponCode, status])
}

enum Role {
  ADMIN
  CUSTOMER
  SELLER
}

enum OrderStatus {
  PENDING
  PAID
  PROOF_SENT
  IN_PRODUCTION
  PROCESSING
  READY
  DELIVERED
  CANCELLED
}

enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  note      String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model ProofFile {
  id         String        @id @default(cuid())
  orderId    String
  fileUrl    String
  fileName   String
  objectKey  String?
  type       ProofFileType @default(PROOF)
  note       String?
  status     ProofStatus   @default(PENDING)
  reviewedAt DateTime?
  reviewNote String?
  createdAt  DateTime      @default(now())
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

enum ProofFileType {
  PROOF
  DELIVERABLE
}

enum PaymentType {
  MERCADOPAGO
  TRANSFER
  CASH
  ZAP_CREDIT
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum PromotionType {
  COUPON
  AUTOMATIC
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum DiscountKind {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CouponStatus {
  AVAILABLE
  RESERVED
  USED
  EXPIRED
}

enum CouponRedemptionStatus {
  RESERVED
  CONFIRMED
  RELEASED
}

enum FinancingRateSource {
  INDEC_AVERAGE
  MANUAL_OVERRIDE
  CUSTOM
}

enum ZapCreditStatus {
  REQUESTED
  QUOTED
  APPROVED
  ACTIVE
  COMPLETED
  REJECTED
  CANCELLED
}

enum ArtworkSubmissionChannel {
  PENDING
  R2
  WHATSAPP
}

enum ZapCreditInstallmentStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum ZapCreditPaymentSubmissionStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum ZapCreditPaymentMethod {
  TRANSFER
  CASH
  OTHER
}

enum ReceiptStatus {
  ACTIVE
  VOIDED
}

model Receipt {
  id             String  @id @default(cuid())
  orderId        String
  installmentId  String?
  sequenceNumber Int
  receiptCode    String

  amount        Float
  concept       String?
  paymentMethod String?

  pdfUrl      String
  pdfFileName String

  status              ReceiptStatus @default(ACTIVE)
  voidedAt            DateTime?
  voidedReason        String?
  replacedByReceiptId String?

  generatedByUserId String
  createdAt         DateTime @default(now())

  order       Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  installment ZapCreditInstallment? @relation(fields: [installmentId], references: [id])

  @@unique([orderId, sequenceNumber])
  @@index([orderId, status])
}
