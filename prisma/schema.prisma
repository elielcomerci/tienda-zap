generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                String                        @id @default(cuid())
  email                             String                        @unique
  password                          String
  role                              Role                          @default(CUSTOMER)
  name                              String?
  phone                             String?
  isBanned                          Boolean                       @default(false)
  sellerId                          String?
  operationalSellerId               String?
  sellerNote                        String?                       @db.Text
  createdAt                         DateTime                      @default(now())
  billingAddress                    String?
  billingCity                       String?
  billingProvince                   String?
  documentId                        String?
  shippingAddress                   String?
  shippingCity                      String?
  shippingPostalCode                String?
  shippingProvince                  String?
  businessTypeId                    String?
  businessType                      BusinessType?                 @relation(fields: [businessTypeId], references: [id])
  accounts                          Account[]
  orders                            Order[]                       @relation("CustomerOrders")
  sellerOrders                      Order[]                       @relation("OrderSeller")
  sessions                          Session[]
  seller                            User?                         @relation("SellerClients", fields: [sellerId], references: [id])
  clients                           User[]                        @relation("SellerClients")
  operationalSeller                 User?                         @relation("OperationalSellerClients", fields: [operationalSellerId], references: [id])
  operationalClients                User[]                        @relation("OperationalSellerClients")
  sellerLeads                       SellerLead[]                  @relation("SellerLeadOwner")
  convertedLeads                    SellerLead[]                  @relation("SellerLeadConvertedUser")
  businessAccounts                  BusinessAccount[]             @relation("BusinessAccountUser")
  assignedBusinessAccounts          BusinessAccount[]             @relation("BusinessAccountSeller")
  operationalBusinessAccounts       BusinessAccount[]             @relation("BusinessAccountOperationalSeller")
  sellerProfile                     SellerProfile?
  incentiveProgress                 SellerIncentiveProgress[]
  sellerPayouts                     SellerPayout[]
  sellerCommissionLedgers           SellerCommissionLedger[]      @relation("SellerCommissionSeller")
  clientCommissionLedgers           SellerCommissionLedger[]      @relation("SellerCommissionClient")
  sellerRankEvents                  SellerRankEvent[]
  ownedRecurringSubscriptions       SellerRecurringSubscription[] @relation("RecurringPortfolioSeller")
  operationalRecurringSubscriptions SellerRecurringSubscription[] @relation("RecurringOperationalSeller")
  clientRecurringSubscriptions      SellerRecurringSubscription[] @relation("RecurringClient")
}

model SellerProfile {
  id                      String              @id @default(cuid())
  userId                  String              @unique
  defaultCommissionRate   Float               @default(20.0)
  rank                    SellerRank          @default(BRONZE)
  maxRankAchieved         SellerRank          @default(BRONZE)
  lifetimeNetRevenue      Float               @default(0)
  temporaryCommissionRate Float?
  temporaryRateExpiresAt  DateTime?
  excludeFromLeaderboards Boolean             @default(false)
  status                  SellerProfileStatus @default(ACTIVE)
  active                  Boolean             @default(true)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessType {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  categories  Category[]
  users       User[]
  sellerLeads SellerLead[]
  accounts    BusinessAccount[]
  combos      Product[]         @relation("ComboBusinessTypes")
}

model BusinessAccount {
  id                  String                @id @default(cuid())
  name                String
  legalName           String?
  taxId               String?
  businessTypeId      String?
  status              BusinessAccountStatus @default(PROSPECT)
  source              String?
  tags                String[]              @default([])
  notes               String?               @db.Text
  nextActionAt        DateTime?
  assignedSellerId    String?
  operationalSellerId String?
  userId              String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  businessType      BusinessType?     @relation(fields: [businessTypeId], references: [id])
  assignedSeller    User?             @relation("BusinessAccountSeller", fields: [assignedSellerId], references: [id])
  operationalSeller User?             @relation("BusinessAccountOperationalSeller", fields: [operationalSellerId], references: [id])
  user              User?             @relation("BusinessAccountUser", fields: [userId], references: [id])
  contacts          BusinessContact[]
  coupons           PromotionCoupon[]

  @@index([name])
  @@index([status, nextActionAt])
  @@index([businessTypeId])
  @@index([assignedSellerId, status])
}

model BusinessContact {
  id        String   @id @default(cuid())
  accountId String
  firstName String
  lastName  String?
  role      String?
  email     String?
  phone     String?
  whatsapp  String?
  isPrimary Boolean  @default(false)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account BusinessAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  coupons PromotionCoupon[]

  @@index([accountId, isPrimary])
  @@index([email])
  @@index([phone])
}

model SellerLead {
  id              String           @id @default(cuid())
  sellerId        String
  name            String
  email           String?
  phone           String?
  businessName    String?
  businessTypeId  String?
  interest        String?
  status          SellerLeadStatus @default(NEW)
  notes           String?          @db.Text
  nextContactAt   DateTime?
  convertedUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  seller        User              @relation("SellerLeadOwner", fields: [sellerId], references: [id], onDelete: Cascade)
  businessType  BusinessType?     @relation(fields: [businessTypeId], references: [id])
  convertedUser User?             @relation("SellerLeadConvertedUser", fields: [convertedUserId], references: [id])
  events        SellerLeadEvent[]

  @@index([sellerId, status])
  @@index([sellerId, nextContactAt])
  @@index([email])
  @@index([phone])
}

model SellerLeadEvent {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  note      String?
  createdAt DateTime @default(now())

  lead SellerLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model SiteSettings {
  id                     String   @id @default("site-settings")
  siteTitle              String   @default("ZAP Tienda - Agencia Creativa")
  siteDescription        String   @default("Piezas graficas, diseño y produccion para marcas que cuidan como se ven.")
  metaKeywords           String?
  canonicalUrl           String?
  ogImageUrl             String?
  googleAnalyticsId      String?
  googleAdsId            String?
  googleTagManagerId     String?
  googleSiteVerification String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorEmail  String?
  action      String
  entityType  String
  entityId    String?
  description String?
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model Category {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  isService     Boolean        @default(false)
  products      Product[]
  businessTypes BusinessType[]
  rawMaterials  RawMaterial[]  @relation("RawMaterialCategories")
}

model Intention {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  icon        String?
  description String?
  mediaType   String?  @default("NONE") // "YOUTUBE", "AUDIO", "NONE"
  mediaUrl    String?
  mediaTitle  String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[] @relation("ProductIntentions")
}

model Product {
  id                       String               @id @default(cuid())
  name                     String
  slug                     String               @unique
  description              String?
  price                    Float
  images                   String[]
  categoryId               String
  active                   Boolean              @default(true)
  stock                    Int                  @default(0)
  isCombo                  Boolean              @default(false)
  comboPricingMode         String               @default("FIXED")
  comboDiscountPercent     Float                @default(0)
  briefType                String?              @default("NONE")
  mediaType                String?              @default("NONE")
  mediaUrl                 String?
  mediaTitle               String?
  mediaList                Json?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  creditDownPaymentPercent Int                  @default(30)
  orderItems               OrderItem[]
  category                 Category             @relation(fields: [categoryId], references: [id])
  options                  ProductOption[]
  outgoingRelations        ProductRelation[]    @relation("ProductOutgoingRelations")
  incomingRelations        ProductRelation[]    @relation("ProductIncomingRelations")
  variants                 ProductVariant[]
  intentions               Intention[]          @relation("ProductIntentions")
  quoterConfig             ProductQuoterConfig?
  targetBusinessTypes      BusinessType[]       @relation("ComboBusinessTypes")
}

model Order {
  id                    String                   @id @default(cuid())
  userId                String?
  sellerId              String?
  guestEmail            String?
  guestName             String?
  guestPhone            String?
  subtotal              Float?
  discountTotal         Float                    @default(0)
  total                 Float
  couponCode            String?
  pricingSnapshot       Json?
  status                OrderStatus              @default(PENDING)
  paymentType           PaymentType
  paymentId             String?
  commissionAmount      Float?
  receiptUrl            String?
  invoiceUrl            String?
  invoiceFileName       String?
  invoiceUploadedAt     DateTime?
  notes                 String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  publicAccessTokenHash String?
  mpPreferenceId        String?
  partnerAccountId      String?
  billingAddress        String?
  billingCity           String?
  billingProvince       String?
  documentId            String?
  shippingAddress       String?
  shippingCity          String?
  shippingPostalCode    String?
  shippingProvince      String?
  partnerAccount        PartnerAccount?          @relation(fields: [partnerAccountId], references: [id])
  user                  User?                    @relation("CustomerOrders", fields: [userId], references: [id])
  seller                User?                    @relation("OrderSeller", fields: [sellerId], references: [id])
  items                 OrderItem[]
  couponRedemption      CouponRedemption?
  zapCreditPlan         ZapCreditPlan?
  receipts              Receipt[]
  events                OrderEvent[]
  proofs                ProofFile[]
  commissionLedgers     SellerCommissionLedger[]
}

model OrderItem {
  id                       String                   @id @default(cuid())
  orderId                  String
  productId                String
  quantity                 Int
  unitPrice                Float
  notes                    String?
  briefType                String?                  @default("NONE")
  briefResponses           Json?
  briefReferenceLinks      String[]
  briefReferenceFiles      Json?
  designRequested          Boolean                  @default(false)
  fileUrl                  String?
  artworkSubmissionChannel ArtworkSubmissionChannel @default(PENDING)
  fileContentType          String?
  fileObjectKey            String?
  fileOriginalName         String?
  fileSizeBytes            Int?
  fileUploadedAt           DateTime?
  isService                Boolean                  @default(false)
  creditDownPaymentPercent Int                      @default(30)
  order                    Order                    @relation(fields: [orderId], references: [id])
  product                  Product                  @relation(fields: [productId], references: [id])
  selectedOptions          OrderItemOption[]
}

model FinancingSettings {
  id                                  String           @id @default("default")
  indecSeriesId                       String           @default("101.1_I2NG_2016_M_22")
  manualRatePercent                   Float?
  defaultInstallments                 Int              @default(6)
  defaultPaymentFrequency             PaymentFrequency @default(MONTHLY)
  cardInstallments                    Int              @default(6)
  createdAt                           DateTime         @default(now())
  updatedAt                           DateTime         @updatedAt
  delinquentDownPaymentPenaltyPercent Int              @default(10)
  delinquentRatePenaltyPercent        Float            @default(8)
}

model ZapCreditPlan {
  id                  String                       @id @default(cuid())
  orderId             String                       @unique
  status              ZapCreditStatus              @default(REQUESTED)
  rateSource          FinancingRateSource          @default(INDEC_AVERAGE)
  indecAveragePercent Float?
  ratePercent         Float
  installments        Int
  paymentFrequency    PaymentFrequency             @default(MONTHLY)
  firstDueDate        DateTime?
  baseAmount          Float
  downPaymentPercent  Float
  downPaymentAmount   Float
  financedAmount      Float
  installmentAmount   Float
  totalRepayable      Float
  totalInterest       Float
  notes               String?
  quotedAt            DateTime?
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  scheduleItems       ZapCreditInstallment[]
  paymentSubmissions  ZapCreditPaymentSubmission[]
  order               Order                        @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ZapCreditInstallment {
  id                   String                       @id @default(cuid())
  planId               String
  sequence             Int
  dueDate              DateTime
  amount               Float
  principalAmount      Float
  interestAmount       Float
  balanceAfter         Float
  status               ZapCreditInstallmentStatus   @default(PENDING)
  approvedSubmissionId String?
  submittedAt          DateTime?
  approvedAt           DateTime?
  reviewNotes          String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  mpPreferenceId       String?
  plan                 ZapCreditPlan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  submissions          ZapCreditPaymentSubmission[]
  receipts             Receipt[]

  @@unique([planId, sequence])
}

model ZapCreditPaymentSubmission {
  id                      String                           @id @default(cuid())
  installmentId           String
  planId                  String
  submittedByUserId       String?
  reviewedByUserId        String?
  paymentMethod           ZapCreditPaymentMethod           @default(TRANSFER)
  amount                  Float
  proofUrl                String
  proofFileName           String
  proofContentType        String?
  proofSizeBytes          Int?
  proofHash               String
  duplicateOfSubmissionId String?
  notes                   String?
  reviewNotes             String?
  status                  ZapCreditPaymentSubmissionStatus @default(SUBMITTED)
  reviewedAt              DateTime?
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  duplicateOfSubmission   ZapCreditPaymentSubmission?      @relation("CreditSubmissionDuplicates", fields: [duplicateOfSubmissionId], references: [id])
  duplicateSubmissions    ZapCreditPaymentSubmission[]     @relation("CreditSubmissionDuplicates")
  installment             ZapCreditInstallment             @relation(fields: [installmentId], references: [id], onDelete: Cascade)
  plan                    ZapCreditPlan                    @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, status])
  @@index([proofHash])
}

model OrderItemOption {
  id          String    @id @default(cuid())
  orderItemId String
  optionName  String
  valueName   String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model ProductOption {
  id          String               @id @default(cuid())
  productId   String
  name        String
  displayType String               @default("BUTTON")
  sortOrder   Int                  @default(0)
  isRequired  Boolean              @default(true)
  product     Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values      ProductOptionValue[]
}

model ProductOptionValue {
  id        String          @id @default(cuid())
  optionId  String
  value     String
  colorHex  String?
  sortOrder Int             @default(0)
  option    ProductOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variants  VariantOption[]
}

model ProductVariant {
  id        String              @id @default(cuid())
  productId String
  price     Float
  sku       String?
  stock     Int?
  imageUrl  String?
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  options   VariantOption[]
  costing   ProductVariantCost?
}

model ProductVariantCost {
  id               String         @id @default(cuid())
  variantId        String         @unique
  rawMaterialId    String?
  providerCost     Float
  providerCurrency String         @default("ARS")
  markup           Float?
  sourceLabel      String?
  sourceRef        String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  rawMaterial      RawMaterial?   @relation(fields: [rawMaterialId], references: [id])

  @@index([rawMaterialId])
  @@map("product_variant_costs")
}

model ProductRelation {
  id               String   @id @default(cuid())
  productId        String
  relatedProductId String
  createdAt        DateTime @default(now())
  product          Product  @relation("ProductOutgoingRelations", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct   Product  @relation("ProductIncomingRelations", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
}

model VariantOption {
  id            String             @id @default(cuid())
  variantId     String
  optionValueId String
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PartnerAccount {
  id                 String   @id @default(cuid())
  kiosco24BranchId   String   @unique
  kiosco24BranchName String
  kiosco24AccessKey  String   @unique
  kiosco24OwnerEmail String?
  logoUrl            String?
  primaryColor       String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  orders             Order[]

  @@index([kiosco24AccessKey])
}

model PartnerCampaign {
  id              String   @id @default(cuid())
  zone            String
  format          String
  title           String
  description     String?
  ctaText         String?
  imageUrl        String?
  backgroundColor String?
  textColor       String?
  actionType      String
  actionUrl       String?
  productId       String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  discountKind    String?
  discountValue   Float?
  promoType       String?

  @@index([zone, active])
}

model Promotion {
  id                  String          @id @default(cuid())
  name                String
  type                PromotionType   @default(COUPON)
  status              PromotionStatus @default(DRAFT)
  campaignKind        String?
  audienceLabel       String?
  qrBaseUrl           String?
  priority            Int             @default(0)
  stackable           Boolean         @default(false)
  activeFrom          DateTime?
  activeTo            DateTime?
  discountKind        DiscountKind
  discountValue       Float
  maxUses             Int?
  perUserLimit        Int?
  minOrderAmount      Float?
  firstOrderOnly      Boolean         @default(false)
  allowedProductIds   String[]        @default([])
  excludedProductIds  String[]        @default([])
  allowedCategoryIds  String[]        @default([])
  excludedCategoryIds String[]        @default([])

  welcomeTitle      String?
  welcomeMessage    String?
  welcomeConditions String?
  welcomeLogoUrl    String?

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  coupons     PromotionCoupon[]
  redemptions CouponRedemption[]
}

model PromotionCoupon {
  code              String             @id
  promotionId       String
  status            CouponStatus       @default(AVAILABLE)
  usesLeft          Int                @default(1)
  recipientName     String?
  recipientBusiness String?
  recipientEmail    String?
  recipientPhone    String?
  businessAccountId String?
  businessContactId String?
  batchName         String?
  qrPayload         String?
  scanCount         Int                @default(0)
  lastScannedAt     DateTime?
  metadata          Json?
  expiresAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  promotion         Promotion          @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  businessAccount   BusinessAccount?   @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  businessContact   BusinessContact?   @relation(fields: [businessContactId], references: [id], onDelete: SetNull)
  redemptions       CouponRedemption[]
  scans             CouponScan[]

  @@index([promotionId, status])
  @@index([batchName])
  @@index([businessAccountId])
  @@index([businessContactId])
}

model CouponScan {
  id         String          @id @default(cuid())
  couponCode String
  scannedAt  DateTime        @default(now())
  userAgent  String?
  referrer   String?
  coupon     PromotionCoupon @relation(fields: [couponCode], references: [code], onDelete: Cascade)

  @@index([couponCode, scannedAt])
}

model CouponRedemption {
  id             String                 @id @default(cuid())
  orderId        String                 @unique
  promotionId    String
  couponCode     String
  status         CouponRedemptionStatus @default(RESERVED)
  discountAmount Float
  createdAt      DateTime               @default(now())
  confirmedAt    DateTime?
  releasedAt     DateTime?
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotion      Promotion              @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  coupon         PromotionCoupon        @relation(fields: [couponCode], references: [code], onDelete: Cascade)

  @@index([promotionId, status])
  @@index([couponCode, status])
}

enum Role {
  ADMIN
  CUSTOMER
  SELLER
}

enum SellerRank {
  BRONZE
  SILVER
  GOLD
  DIAMOND
}

enum SellerProfileStatus {
  ACTIVE
  RETIRED
  SUSPENDED
}

enum SellerRankEventType {
  AUTOMATIC_PROMOTION
  MANUAL_CHANGE
  TEMPORARY_OVERRIDE
  PENALTY
}

enum SellerCommissionType {
  STORE
  SPOT
  MANUAL
  RECURRING
  ROYALTY
  BONUS
  ADJUSTMENT
}

enum SellerCommissionStatus {
  PENDING
  AVAILABLE
  PAID_OUT
  CANCELLED
}

enum RecurringSubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum SellerLeadStatus {
  NEW
  CONTACTED
  QUOTED
  WON
  LOST
}

enum BusinessAccountStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  LOST
}

enum OrderStatus {
  PENDING
  PAID
  PROOF_SENT
  IN_PRODUCTION
  PROCESSING
  READY
  DELIVERED
  CANCELLED
}

enum ProofStatus {
  PENDING
  APPROVED
  REJECTED
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  note      String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model ProofFile {
  id         String        @id @default(cuid())
  orderId    String
  fileUrl    String
  fileName   String
  objectKey  String?
  type       ProofFileType @default(PROOF)
  note       String?
  status     ProofStatus   @default(PENDING)
  reviewedAt DateTime?
  reviewNote String?
  createdAt  DateTime      @default(now())
  order      Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

enum ProofFileType {
  PROOF
  DELIVERABLE
}

enum PaymentType {
  MERCADOPAGO
  TRANSFER
  CASH
  ZAP_CREDIT
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum PromotionType {
  COUPON
  AUTOMATIC
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum DiscountKind {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CouponStatus {
  AVAILABLE
  RESERVED
  USED
  EXPIRED
}

enum CouponRedemptionStatus {
  RESERVED
  CONFIRMED
  RELEASED
}

enum FinancingRateSource {
  INDEC_AVERAGE
  MANUAL_OVERRIDE
  CUSTOM
}

enum ZapCreditStatus {
  REQUESTED
  QUOTED
  APPROVED
  ACTIVE
  COMPLETED
  REJECTED
  CANCELLED
}

enum ArtworkSubmissionChannel {
  PENDING
  R2
  WHATSAPP
}

enum ZapCreditInstallmentStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  CANCELLED
}

enum ZapCreditPaymentSubmissionStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum ZapCreditPaymentMethod {
  TRANSFER
  CASH
  OTHER
}

enum ReceiptStatus {
  ACTIVE
  VOIDED
}

model Receipt {
  id             String  @id @default(cuid())
  orderId        String
  installmentId  String?
  sequenceNumber Int
  receiptCode    String

  amount        Float
  concept       String?
  paymentMethod String?

  pdfUrl      String
  pdfFileName String

  status              ReceiptStatus @default(ACTIVE)
  voidedAt            DateTime?
  voidedReason        String?
  replacedByReceiptId String?

  generatedByUserId String
  createdAt         DateTime @default(now())

  order       Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  installment ZapCreditInstallment? @relation(fields: [installmentId], references: [id])

  @@unique([orderId, sequenceNumber])
  @@index([orderId, status])
}

model SellerIncentive {
  id           String   @id @default(cuid())
  title        String // e.g. "Bono de Fin de Semana"
  description  String? // e.g. "Cerrá 5 ventas este fin de semana y ganá un bono de $10.000"
  goalType     String // "SALES_COUNT", "TOTAL_REVENUE"
  goalTarget   Float // e.g. 5 (for count), 100000 (for revenue)
  rewardType   String // "FIXED_BONUS"
  rewardAmount Float // e.g. 10000
  startDate    DateTime
  endDate      DateTime
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sellerProgress SellerIncentiveProgress[]
}

model SellerIncentiveProgress {
  id            String    @id @default(cuid())
  sellerId      String
  incentiveId   String
  currentValue  Float     @default(0)
  completed     Boolean   @default(false)
  completedAt   DateTime?
  rewardClaimed Boolean   @default(false)

  seller    User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  incentive SellerIncentive @relation(fields: [incentiveId], references: [id], onDelete: Cascade)

  @@unique([sellerId, incentiveId])
}

model SellerPayout {
  id        String   @id @default(cuid())
  sellerId  String
  amount    Float
  reference String?
  createdAt DateTime @default(now())

  seller      User                     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  commissions SellerCommissionLedger[]

  @@index([sellerId])
}

model SellerRankEvent {
  id          String              @id @default(cuid())
  sellerId    String
  fromRank    SellerRank?
  toRank      SellerRank
  eventType   SellerRankEventType
  reason      String?             @db.Text
  createdById String?
  createdAt   DateTime            @default(now())

  seller User @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId, createdAt])
}

model SellerCommissionLedger {
  id             String                 @id @default(cuid())
  sellerId       String
  clientId       String?
  orderId        String?
  recurringId    String?
  payoutId       String?
  period         String?
  type           SellerCommissionType
  status         SellerCommissionStatus @default(PENDING)
  baseAmount     Float
  commissionRate Float
  amount         Float
  rank           SellerRank?
  notes          String?                @db.Text
  availableAt    DateTime?
  paidOutAt      DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  seller    User                         @relation("SellerCommissionSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  client    User?                        @relation("SellerCommissionClient", fields: [clientId], references: [id])
  order     Order?                       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recurring SellerRecurringSubscription? @relation(fields: [recurringId], references: [id], onDelete: SetNull)
  payout    SellerPayout?                @relation(fields: [payoutId], references: [id], onDelete: SetNull)

  @@unique([sellerId, orderId, type])
  @@unique([sellerId, recurringId, type, period])
  @@index([sellerId, status])
  @@index([orderId])
  @@index([recurringId, period])
  @@index([payoutId])
}

model SellerRecurringSubscription {
  id                  String                      @id @default(cuid())
  clientId            String
  portfolioSellerId   String
  operationalSellerId String?
  name                String
  monthlyAmount       Float
  dueDay              Int
  status              RecurringSubscriptionStatus @default(ACTIVE)
  startedAt           DateTime                    @default(now())
  pausedAt            DateTime?
  cancelledAt         DateTime?
  notes               String?                     @db.Text
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  client            User                     @relation("RecurringClient", fields: [clientId], references: [id])
  portfolioSeller   User                     @relation("RecurringPortfolioSeller", fields: [portfolioSellerId], references: [id])
  operationalSeller User?                    @relation("RecurringOperationalSeller", fields: [operationalSellerId], references: [id])
  commissions       SellerCommissionLedger[]

  @@index([clientId])
  @@index([portfolioSellerId, status])
  @@index([operationalSellerId])
}

// ==========================================
// SISTEMA DE COTIZACIONES Y COSTOS
// ==========================================

model RawMaterial {
  id                    String                        @id @default(cuid())
  name                  String
  width                 Float // Ancho del pliego/material en cm
  height                Float // Alto del pliego/material en cm
  unit                  String                        @default("PLIEGO") // PLIEGO, M2, METRO LINEAL, etc.
  active                Boolean                       @default(true)
  createdAt             DateTime                      @default(now())
  updatedAt             DateTime                      @updatedAt
  tiers                 RawMaterialTier[]
  configs               ProductQuoterConfig[]
  quoterConfigMaterials ProductQuoterConfigMaterial[]
  variantCosts          ProductVariantCost[]
  applicableCategories  Category[]                    @relation("RawMaterialCategories")

  @@map("raw_materials")
}

model RawMaterialTier {
  id            String      @id @default(cuid())
  rawMaterialId String
  minQty        Int
  maxQty        Int?
  unitPrice     Float // Costo por unidad en este rango de cantidades
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@index([rawMaterialId])
  @@map("raw_material_tiers")
}

enum FinishingCostType {
  FIXED_SETUP
  PER_SHEET
  PER_UNIT
}

model FinishingOperation {
  id        String                  @id @default(cuid())
  name      String
  costType  FinishingCostType
  active    Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  tiers     FinishingTier[]
  configs   QuoterConfigFinishing[]

  @@map("finishing_operations")
}

model FinishingTier {
  id          String             @id @default(cuid())
  finishingId String
  minQty      Int
  maxQty      Int?
  unitPrice   Float
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  finishing   FinishingOperation @relation(fields: [finishingId], references: [id], onDelete: Cascade)

  @@index([finishingId])
  @@map("finishing_tiers")
}

model ProductQuoterConfig {
  id               String                        @id @default(cuid())
  productId        String                        @unique
  rawMaterialId    String?
  itemWidth        Float? // Ancho del producto en cm
  itemHeight       Float? // Alto del producto en cm
  margin           Float                         @default(0) // Margen de corte/agarre (cm)
  bleed            Float                         @default(0) // Demasía (cm)
  profitMargin     Float                         @default(150) // Porcentaje de ganancia (ej: 150 = +150%)
  minProfitMargin  Float?
  maxProfitMargin  Float?
  pricingMode      String                        @default("SHEET_NESTING")
  allowCustomSize  Boolean                       @default(false)
  minWidth         Float?
  maxWidth         Float?
  minHeight        Float?
  maxHeight        Float?
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  product          Product                       @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial      RawMaterial?                  @relation(fields: [rawMaterialId], references: [id])
  finishings       QuoterConfigFinishing[]
  allowedMaterials ProductQuoterConfigMaterial[]
  quantityPresets  ProductQuoterQuantityPreset[]
  sizePresets      ProductQuoterSizePreset[]

  @@index([rawMaterialId])
  @@map("product_quoter_configs")
}

model ProductQuoterConfigMaterial {
  configId      String
  rawMaterialId String
  label         String?
  createdAt     DateTime            @default(now())
  config        ProductQuoterConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial         @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@id([configId, rawMaterialId])
  @@index([rawMaterialId])
  @@map("product_quoter_config_materials")
}

model ProductQuoterQuantityPreset {
  id        String              @id @default(cuid())
  configId  String
  quantity  Int
  label     String?
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  config    ProductQuoterConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, quantity])
  @@index([configId])
  @@map("product_quoter_quantity_presets")
}

model ProductQuoterSizePreset {
  id        String              @id @default(cuid())
  configId  String
  label     String
  width     Float
  height    Float
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  config    ProductQuoterConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@unique([configId, label])
  @@index([configId])
  @@map("product_quoter_size_presets")
}

model QuoterConfigFinishing {
  configId    String
  finishingId String
  createdAt   DateTime            @default(now())
  config      ProductQuoterConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  finishing   FinishingOperation  @relation(fields: [finishingId], references: [id], onDelete: Cascade)

  @@id([configId, finishingId])
  @@index([finishingId])
  @@map("quoter_config_finishings")
}
