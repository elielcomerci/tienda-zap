// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  name      String?
  phone     String?
  orders    Order[]
  createdAt DateTime @default(now())

  // NextAuth
  accounts Account[]
  sessions Session[]
}

enum Role {
  ADMIN
  CUSTOMER
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  isService Boolean   @default(false)
  products  Product[]
}

model Product {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  description       String?
  price             Float
  creditDownPaymentPercent Int       @default(30)
  images            String[]
  categoryId        String
  category          Category          @relation(fields: [categoryId], references: [id])
  active            Boolean           @default(true)
  stock             Int               @default(0) // Stock general (si aplica)
  
  // Configurador Avanzado
  options           ProductOption[]
  variants          ProductVariant[]
  outgoingRelations ProductRelation[] @relation("ProductOutgoingRelations")
  incomingRelations ProductRelation[] @relation("ProductIncomingRelations")
  
  orderItems        OrderItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Order {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  publicAccessTokenHash String?
  guestEmail  String?
  guestName   String?
  guestPhone  String?
  items       OrderItem[]
  total       Float
  status      OrderStatus @default(PENDING)
  paymentType PaymentType
  paymentId   String?
  receiptUrl  String?
  notes       String?
  zapCreditPlan ZapCreditPlan?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentType {
  MERCADOPAGO
  TRANSFER
  CASH
  ZAP_CREDIT
}

enum PaymentFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum FinancingRateSource {
  INDEC_AVERAGE
  MANUAL_OVERRIDE
  CUSTOM
}

enum ZapCreditStatus {
  REQUESTED
  QUOTED
  APPROVED
  ACTIVE
  COMPLETED
  REJECTED
  CANCELLED
}

enum ArtworkSubmissionChannel {
  PENDING
  R2
  WHATSAPP
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity          Int
  unitPrice         Float
  creditDownPaymentPercent Int @default(30)
  notes             String?
  isService         Boolean @default(false)
  fileUrl           String?
  fileObjectKey     String?
  fileOriginalName  String?
  fileContentType   String?
  fileSizeBytes     Int?
  fileUploadedAt    DateTime?
  artworkSubmissionChannel ArtworkSubmissionChannel @default(PENDING)
  designRequested   Boolean @default(false)
  
  // Opciones seleccionadas para este ítem
  selectedOptions   OrderItemOption[]
}

model FinancingSettings {
  id                      String           @id @default("default")
  indecSeriesId           String           @default("101.1_I2NG_2016_M_22")
  manualRatePercent       Float?
  defaultInstallments     Int              @default(6)
  defaultPaymentFrequency PaymentFrequency @default(MONTHLY)
  cardInstallments        Int              @default(6)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
}

model ZapCreditPlan {
  id                 String              @id @default(cuid())
  orderId            String              @unique
  order              Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status             ZapCreditStatus     @default(REQUESTED)
  rateSource         FinancingRateSource @default(INDEC_AVERAGE)
  indecAveragePercent Float?
  ratePercent        Float
  installments       Int
  paymentFrequency   PaymentFrequency    @default(MONTHLY)
  firstDueDate       DateTime?
  baseAmount         Float
  downPaymentPercent Float
  downPaymentAmount  Float
  financedAmount     Float
  installmentAmount  Float
  totalRepayable     Float
  totalInterest      Float
  notes              String?
  quotedAt           DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model OrderItemOption {
  id              String         @id @default(cuid())
  orderItem       OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  orderItemId     String
  optionName      String         // Ej: "Cantidad a Imprimir"
  valueName       String         // Ej: "250 unidades"
}

// ==== Configurador Avanzado de Productos ====

model ProductOption {
  id          String   @id @default(cuid())
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  name        String   // Ej: "Terminación", "Cantidad"
  isRequired  Boolean  @default(true)
  values      ProductOptionValue[]
}

model ProductOptionValue {
  id          String         @id @default(cuid())
  option      ProductOption  @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId    String
  value       String         // Ej: "Laminado Mate", "100u"
  
  // Relación a las variantes que incluyen este valor
  variants    VariantOption[]
}

model ProductVariant {
  id          String           @id @default(cuid())
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId   String
  price       Float            // Precio final de esta combinación exacta
  sku         String?          
  stock       Int?             // Opcional, si queremos llevar stock por variante
  
  // Relación con los valores específicos que forman esta combinación
  options     VariantOption[]
}

model ProductRelation {
  id               String   @id @default(cuid())
  productId        String
  relatedProductId String
  createdAt        DateTime @default(now())

  product        Product @relation("ProductOutgoingRelations", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("ProductIncomingRelations", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
}

// Tabla pivote para unir Variantes con sus Valores Específicos
model VariantOption {
  id          String               @id @default(cuid())
  variant     ProductVariant       @relation(fields: [variantId], references: [id], onDelete: Cascade)
  variantId   String
  optionValue ProductOptionValue   @relation(fields: [optionValueId], references: [id], onDelete: Cascade)
  optionValueId String

  @@unique([variantId, optionValueId])
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
